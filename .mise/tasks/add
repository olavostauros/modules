#!/usr/bin/env bash
#MISE description="Add a submodule"
#MISE dir="{{config_root}}"
#USAGE arg "<url>" help="Git URL of the repo to add"
#USAGE flag "--name <name>" help="Module name (default: derived from URL)"
#USAGE flag "--ref <ref>" help="Git ref to pin (default: HEAD)"
#USAGE flag "--track <ref>" help="Track this ref during init/update while retaining a pinned SHA"
set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"

require_git
require_initialized

url="$usage_url"

if [ -n "${usage_name:-}" ]; then
  name="$usage_name"
else
  name="$(basename "$url" .git)"
  name="${name%/}"
fi

if [ -z "$name" ] || [[ "$name" == *"/"* ]] || [[ "$name" == "."* ]]; then
  echo "Error: invalid module name: '$name'" >&2
  echo "Use --name to provide an explicit name." >&2
  exit 1
fi

if manifest_has "$name"; then
  echo "Error: module '$name' already exists" >&2
  exit 1
fi

mod_path="$(module_path "$name")"
clones_rel="$(clones_path_rel)"

if [ -d "$mod_path" ]; then
  echo "Error: directory already exists: $clones_rel/$name" >&2
  exit 1
fi

mkdir -p "$(clones_dir)"
gum spin --title "Cloning $url → $clones_rel/$name" -- git clone "$url" "$mod_path"

checkout_ref="${usage_ref:-}"
track_ref="${usage_track:-}"
if [ -z "$checkout_ref" ] && [ -n "$track_ref" ]; then
  checkout_ref="$track_ref"
fi

if [ -n "$checkout_ref" ]; then
  git -C "$mod_path" checkout "$checkout_ref"
fi

pin="$(git -C "$mod_path" rev-parse HEAD)"

manifest_set "$name" "$url" "$pin" "$track_ref"

git -C "$TARGET_DIR" add "$MANIFEST"

if [ -n "$track_ref" ]; then
  gum style --foreground 2 "Added module '$name' ($clones_rel/$name @ ${pin:0:12}, tracking $track_ref)"
else
  gum style --foreground 2 "Added module '$name' ($clones_rel/$name @ ${pin:0:12})"
fi
