#!/usr/bin/env bash
#MISE description="Clone modules and refresh tracked clones from their branch"
#MISE dir="{{config_root}}"
#USAGE arg "[names]..." var=#true help="Module names to initialize (omit to initialize all)"
set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"

require_git
require_initialized

module_selected() {
  local candidate="$1" wanted
  shift

  if [ "$#" -eq 0 ]; then
    return 0
  fi

  for wanted in "$@"; do
    if [ "$candidate" = "$wanted" ]; then
      return 0
    fi
  done

  return 1
}

validate_selected_modules() {
  local wanted errors=0

  for wanted in "$@"; do
    if ! manifest_has "$wanted"; then
      echo "Error: module '$wanted' not found" >&2
      errors=$((errors + 1))
    fi
  done

  [ "$errors" -eq 0 ]
}

if ! validate_selected_modules "$@"; then
  exit 1
fi

count="$(manifest_count)"

if [ "$count" -eq 0 ]; then
  echo "No modules to initialize."
  exit 0
fi

mkdir -p "$(clones_dir)"
clones_rel="$(clones_path_rel)"

sync_to_track() {
  local name="$1" mod_path="$2" track="$3"

  sync_tracked_branch "$name" "$mod_path" "$track" || return 1

  local actual
  actual="$(git -C "$mod_path" rev-parse HEAD)"
  echo "  $name: tracking $track @ ${actual:0:12}"
}

errors=0

while IFS=$'\t' read -r name url pin track; do
  [ -z "$name" ] && continue
  if ! module_selected "$name" "$@"; then
    continue
  fi

  track="${track:-}"
  mod_path="$(module_path "$name")"

  if [ -d "$mod_path/.git" ]; then
    if [ -n "$track" ]; then
      sync_to_track "$name" "$mod_path" "$track" || errors=$((errors + 1))
    else
      echo "  $name: already cloned"
    fi
    continue
  fi

  echo "  $name: cloning $url → $clones_rel/$name"

  # If the clone target exists but isn't a git repo, remove it. rmdir
  # handles the empty case; a non-empty dir is an unexpected state
  # (partial clone, leftover user files) — surface it instead of silently
  # letting `git clone` fail with a confusing 'destination path exists'
  # error.
  if [ -d "$mod_path" ]; then
    if ! rmdir "$mod_path" 2>/dev/null; then
      echo "  $name: clone target '$mod_path' exists and is not empty — refusing to clobber" >&2
      echo "  Remove it manually or move its contents aside, then re-run 'modules init'." >&2
      errors=$((errors + 1))
      continue
    fi
  fi

  if ! git clone "$url" "$mod_path" 2>&1; then
    echo "  $name: clone failed" >&2
    errors=$((errors + 1))
    continue
  fi

  if [ -n "$track" ]; then
    sync_to_track "$name" "$mod_path" "$track" || errors=$((errors + 1))
  else
    git -C "$mod_path" checkout "$pin" 2>&1

    actual="$(git -C "$mod_path" rev-parse HEAD)"
    if [ "$actual" != "$pin" ]; then
      echo "  $name: warning — expected $pin, at $actual" >&2
    fi
  fi
done < "$MANIFEST"

if [ "$errors" -gt 0 ]; then
  echo "$errors module(s) failed to initialize" >&2
  exit 1
fi
