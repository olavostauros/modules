#!/usr/bin/env bash
#MISE description="List modules"
#MISE dir="{{config_root}}"
#USAGE flag "--json" help="Output as JSON"
set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"

require_git
require_initialized

if [ "$(manifest_count)" -eq 0 ]; then
  echo "No modules. Use 'modules add <url>' to add one."
  exit 0
fi

if [ "${usage_json:-}" = "true" ]; then
  # Emit as JSON: {name: {url, pin, track?}}. Build via jq -nR so
  # URLs/names containing quotes, backslashes, or control characters are
  # safely escaped (awk-based string interpolation is unsafe).
  jq -nR '
    [ inputs
      | select(length > 0)
      | split("\t")
      | { (.[0]): ({ url: .[1], pin: .[2] } + if (.[3] // "") != "" then { track: .[3] } else {} end) }
    ]
    | add // {}
  ' "$MANIFEST"
  exit 0
fi

{
  printf "Name\tURL\tPin\tTrack\n"
  awk -F'\t' '{ track = (NF >= 4 && $4 != "") ? $4 : "-"; printf "%s\t%s\t%.12s\t%s\n", $1, $2, $3, track }' "$MANIFEST"
} | gum table --print --separator "	"
